{
  "info": {
    "name": "meuN8N API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://api.meun8n.theretech.com.br",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "Tenants",
      "item": [
        {
          "name": "GET /tenants",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/tenants"
          }
        },
        {
          "name": "POST /tenants",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/tenants",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slug\": \"brbit\",\n  \"plan\": \"starter\",\n  \"n8nOwnerEmail\": \"admin@brbit.com.br\"\n}"
            }
          }
        },
        {
          "name": "GET /tenants/:slug",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/tenants/brbit"
          }
        },
        {
          "name": "PATCH /tenants/:slug",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/tenants/brbit",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan\": \"pro\",\n  \"n8nOwnerEmail\": \"novo@brbit.com.br\"\n}"
            }
          }
        },
        {
          "name": "DELETE /tenants/:slug",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/tenants/brbit"
          }
        }
      ]
    }
  ]
}
