# Postgres (apontar para o shared theretech-n8n-db no Railway)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=<railway-internal-host>
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n_<slug-cliente>
DB_POSTGRESDB_USER=<postgres-user>
DB_POSTGRESDB_PASSWORD=<postgres-password>

# n8n
N8N_HOST=<slug-cliente>.meun8n.theretech.com.br
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_EDITOR_BASE_URL=https://<slug-cliente>.meun8n.theretech.com.br
WEBHOOK_URL=https://<slug-cliente>.meun8n.theretech.com.br/

# Chave única por cliente — NUNCA reutilizar entre clientes
N8N_ENCRYPTION_KEY=<gerar com: openssl rand -hex 32>

N8N_SECURE_COOKIE=true
N8N_BASIC_AUTH_ACTIVE=false

GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo
N8N_LOG_LEVEL=info
N8N_RUNNERS_ENABLED=true
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
