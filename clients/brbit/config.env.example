# Postgres (shared theretech-n8n-db no Railway)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=<railway-internal-host>
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n_brbit
DB_POSTGRESDB_USER=<postgres-user>
DB_POSTGRESDB_PASSWORD=<postgres-password>

# n8n
N8N_HOST=brbit.meun8n.theretech.com.br
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_EDITOR_BASE_URL=https://brbit.meun8n.theretech.com.br
WEBHOOK_URL=https://brbit.meun8n.theretech.com.br/

# NUNCA reutilizar esta chave em outro cliente
N8N_ENCRYPTION_KEY=2198d7b9aed869c0e30007fcef631d1a79caf3334752d1f32a754c96bb8988b4

N8N_SECURE_COOKIE=true
N8N_BASIC_AUTH_ACTIVE=false

GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo
N8N_LOG_LEVEL=info
N8N_RUNNERS_ENABLED=true
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
