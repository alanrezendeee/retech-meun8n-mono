# ===== Banco =====
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=troque_essa_senha_forte

# ===== n8n =====
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678/

# Segurança interna do n8n
N8N_ENCRYPTION_KEY=troque_por_uma_chave_bem_grande_e_aleatoria
N8N_SECURE_COOKIE=false

# Basic auth no acesso web
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=troque_por_outra_senha_forte

# Banco Postgres
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=${POSTGRES_DB}
DB_POSTGRESDB_USER=${POSTGRES_USER}
DB_POSTGRESDB_PASSWORD=${POSTGRES_PASSWORD}

# Execução / logs
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo
N8N_LOG_LEVEL=info
N8N_RUNNERS_ENABLED=true

# Opcional: evita alguns problemas de permissão em volume local
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true